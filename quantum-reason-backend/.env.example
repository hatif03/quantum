# K2 Think API (required for hackathon)
K2_THINK_API_KEY=your-key-here
K2_API_BASE=https://api.k2think.ai/v1

# Optional — embeddings for vector KB search
GOOGLE_API_KEY=

# K2-V2-Instruct may be unavailable on some keys; default to Think for both.
# K2_THINK_MODEL=MBZUAI-IFM/K2-Think-v2
# K2_INSTRUCT_MODEL=MBZUAI-IFM/K2-Think-v2

LOG_LEVEL=INFO

# Session debug artifacts (Teach mode): raw K2 responses, parsed JSON, compile logs
# QUANTUM_LOG_DIR=./logs/sessions
# QUANTUM_LOG_RAW_K2=true
# QUANTUM_DEBUG=1

# Production Docker: mount logs volume, e.g. -v ./logs:/app/logs

# Production Docker: comma-separated frontend origins (e.g. https://your-app.vercel.app)
# CORS_ORIGINS=

# Teach pipeline (mode both/teach): max diagram panels and compile retries per panel
# K2_MAX_PANELS=4
# K2_COMPILE_RETRIES=2

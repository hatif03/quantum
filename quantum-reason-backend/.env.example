# K2 Think API (required for hackathon)
K2_THINK_API_KEY=your-key-here
K2_API_BASE=https://api.k2think.ai/v1

# Optional — embeddings for vector KB search
GOOGLE_API_KEY=

# K2-V2-Instruct may be unavailable on some keys; default to Think for both.
# K2_THINK_MODEL=MBZUAI-IFM/K2-Think-v2
# K2_INSTRUCT_MODEL=MBZUAI-IFM/K2-Think-v2

LOG_LEVEL=INFO
